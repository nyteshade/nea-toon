; Install script for toon - TOON format tools for AmigaOS
; Requires AmigaOS 2.0+ (RequestChoice, RequestFile)
;
; Usage: execute Install
;

; --- Welcome ---
RequestChoice SET toonrc TITLE "TOON Installer" BODY "TOON v1.5*n*n  CLI, shared library, SDK" GADGETS "Install|Cancel"
If $toonrc EQ 0
  Echo "Installation cancelled."
  Skip end
EndIf

; --- Check for existing toon.library version ---
If Exists LIBS:toon.library
  Version >NIL: LIBS:toon.library 1 5
  If Not Warn
    RequestChoice SET toonrc TITLE "TOON Installer" BODY "toon.library 1.5+ already installed.*nReinstall?" GADGETS "Yes|No"
    If $toonrc EQ 0
      Skip clionly
    EndIf
  EndIf
EndIf

; --- Select CPU for CLI binary ---
Lab clionly
RequestChoice SET tooncpu TITLE "Select CPU" BODY "Choose the toon CLI binary*nfor your CPU:" GADGETS "68000 (any Amiga)|68020|68040|68060"
If $tooncpu EQ 1
  Set toonbin "C/toon.000"
EndIf
If $tooncpu EQ 2
  Set toonbin "C/toon.020"
EndIf
If $tooncpu EQ 3
  Set toonbin "C/toon.040"
EndIf
If $tooncpu EQ 0
  Set toonbin "C/toon.060"
EndIf

If Not Exists "$toonbin"
  Echo "Error: $toonbin not found."
  Echo "Run Install from the toon release directory."
  Skip end
EndIf

; --- Install CLI to C: ---
Echo "Installing $toonbin to C:toon..."
Copy "$toonbin" C:toon CLONE QUIET
If Warn
  Echo "Warning: Could not copy to C:"
Else
  Echo "  C:toon installed."
EndIf

; --- Install shared library to LIBS: ---
Echo "Installing toon.library to LIBS:..."
If Exists LIBS:toon.library
  Echo "  Replacing existing toon.library..."
EndIf
Copy Libs/toon.library LIBS:toon.library CLONE QUIET
If Warn
  Echo "Warning: Could not copy to LIBS:"
Else
  Echo "  LIBS:toon.library installed."
EndIf

; --- Ask about SDK ---
RequestChoice SET toonsdk TITLE "Developer SDK" BODY "Install SDK?*n*nHeaders, FD, pragmas, toon.lib" GADGETS "Yes|No"
If $toonsdk EQ 0
  Echo "Skipping SDK installation."
  Skip done
EndIf

; --- Ask where to install SDK ---
; RequestFile path includes trailing : or / for direct concatenation
RequestFile SET toondir TITLE "SDK Location" DRAWERSONLY NOICONS
If Warn
  Echo "No directory selected. Skipping SDK."
  Skip done
EndIf

; --- Create SDK directories ---
Echo "Installing SDK to $toondir..."

If Not Exists "$toondir"include
  MakeDir "$toondir"include
EndIf
If Not Exists "$toondir"include/libraries
  MakeDir "$toondir"include/libraries
EndIf
If Not Exists "$toondir"include/proto
  MakeDir "$toondir"include/proto
EndIf
If Not Exists "$toondir"include/pragmas
  MakeDir "$toondir"include/pragmas
EndIf
If Not Exists "$toondir"include/fd
  MakeDir "$toondir"include/fd
EndIf
If Not Exists "$toondir"lib
  MakeDir "$toondir"lib
EndIf

; --- Copy SDK files ---
Echo "  Copying headers..."
Copy sdk/include/libraries/toon.h "$toondir"include/libraries/ CLONE QUIET
Copy sdk/include/proto/toon.h "$toondir"include/proto/ CLONE QUIET
Copy sdk/include/pragmas/toon_pragmas.h "$toondir"include/pragmas/ CLONE QUIET
Copy sdk/fd/toon_lib.fd "$toondir"include/fd/ CLONE QUIET

Echo "  Copying libraries..."
Copy Libs/toon.library "$toondir"lib/ CLONE QUIET
Copy sdk/lib/toon.lib "$toondir"lib/ CLONE QUIET

Echo "  Copying autodoc..."
If Not Exists "$toondir"autodocs
  MakeDir "$toondir"autodocs
EndIf
Copy sdk/autodocs/toon.doc "$toondir"autodocs/ CLONE QUIET

Echo "  Copying example..."
If Not Exists "$toondir"examples
  MakeDir "$toondir"examples
EndIf
Copy sdk/src/lib/toon_example.c "$toondir"examples/ CLONE QUIET

Echo "  SDK installed to $toondir"

; --- Done ---
Lab done
Echo ""
Echo "Installation complete!"
Echo ""
Echo "Quick start:"
Echo "  toon encode file.json"
Echo "  toon decode file.toon"
Echo "  toon get file.toon path"
Echo "  toon set file.toon path val"
Echo "  toon"

Lab end
; Clean up
UnSet toonbin
UnSet toondir
UnSet toonrc
UnSet tooncpu
UnSet toonsdk
