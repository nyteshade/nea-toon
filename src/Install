; Install script for toon - TOON format tools for AmigaOS
; Requires AmigaOS 2.0+ (requestchoice, requestfile)
;
; Usage: execute Install
;

; --- Welcome ---
requestchoice >ENV:toon_rc TITLE "TOON Installer" BODY "TOON v1.2*n*n  CLI, shared library, SDK" GADGETS "Install|Cancel"
If $toon_rc EQ 0
  Echo "Installation cancelled."
  Skip end
EndIf

; --- Check for existing toon.library version ---
If Exists LIBS:toon.library
  Version >NIL: LIBS:toon.library 1 2
  If Not Warn
    requestchoice >ENV:toon_rc TITLE "TOON Installer" BODY "toon.library 1.2+ already installed.*nReinstall?" GADGETS "Yes|No"
    If $toon_rc EQ 0
      Skip clionly
    EndIf
  EndIf
EndIf

; --- Select CPU for CLI binary ---
Lab clionly
requestchoice >ENV:toon_cpu TITLE "Select CPU" BODY "Choose the toon CLI binary*nfor your CPU:" GADGETS "68000 (any Amiga)|68020|68040|68060"
If $toon_cpu EQ 1
  Set toon_bin "toon.000"
EndIf
If $toon_cpu EQ 2
  Set toon_bin "toon.020"
EndIf
If $toon_cpu EQ 3
  Set toon_bin "toon.040"
EndIf
If $toon_cpu EQ 0
  Set toon_bin "toon.060"
EndIf

If Not Exists ${toon_bin}
  Echo "Error: ${toon_bin} not found."
  Echo "Run Install from the toon directory."
  Skip end
EndIf

; --- Install CLI to C: ---
Echo "Installing ${toon_bin} to C:toon..."
Copy ${toon_bin} C:toon CLONE QUIET
If Warn
  Echo "Warning: Could not copy to C:"
Else
  Echo "  C:toon installed."
EndIf

; --- Install shared library to LIBS: ---
Echo "Installing toon.library to LIBS:..."
If Exists LIBS:toon.library
  Echo "  Replacing existing toon.library..."
EndIf
Copy toon.library LIBS:toon.library CLONE QUIET
If Warn
  Echo "Warning: Could not copy to LIBS:"
Else
  Echo "  LIBS:toon.library installed."
EndIf

; --- Ask about SDK ---
requestchoice >ENV:toon_sdk TITLE "Developer SDK" BODY "Install SDK?*n*nHeaders, FD, pragmas, toon.lib" GADGETS "Yes|No"
If $toon_sdk EQ 0
  Echo "Skipping SDK installation."
  Skip done
EndIf

; --- Ask where to install SDK ---
requestfile >ENV:toon_dest TITLE "SDK Location" DRAWERSONLY NOICONS
If Warn
  Echo "No directory selected. Skipping SDK."
  Skip done
EndIf

; --- Create SDK directories and copy files ---
Set toon_dir "${toon_dest}"

If Not Exists "${toon_dir}"
  MakeDir "${toon_dir}"
EndIf

; --- includes ---
Set toon_sub "${toon_dir}/include/libraries"
If Not Exists "${toon_sub}"
  MakeDir "${toon_dir}/include" "${toon_dir}/include/libraries" "${toon_dir}/include/proto" "${toon_dir}/include/pragmas" "${toon_dir}/include/fd"
EndIf

Echo "  Copying headers..."
Copy sdk/include/libraries/toon.h "${toon_dir}/include/libraries/" CLONE QUIET
Copy sdk/include/proto/toon.h "${toon_dir}/include/proto/" CLONE QUIET
Copy sdk/include/pragmas/toon_pragmas.h "${toon_dir}/include/pragmas/" CLONE QUIET
Copy sdk/include/fd/toon_lib.fd "${toon_dir}/include/fd/" CLONE QUIET

; --- libs ---
If Not Exists "${toon_dir}/lib"
  MakeDir "${toon_dir}/lib"
EndIf

Echo "  Copying libraries..."
Copy toon.library "${toon_dir}/lib/" CLONE QUIET
Copy sdk/toon.lib "${toon_dir}/lib/" CLONE QUIET

; --- example ---
If Not Exists "${toon_dir}/examples"
  MakeDir "${toon_dir}/examples"
EndIf

Echo "  Copying example..."
Copy sdk/toon_example.c "${toon_dir}/examples/" CLONE QUIET

Echo "  SDK installed to ${toon_dir}"

; --- Done ---
Lab done
Echo ""
Echo "Installation complete!"
Echo ""
Echo "Quick start:"
Echo "  toon encode file.json"
Echo "  toon decode file.toon"
Echo "  toon get file.toon path"
Echo "  toon set file.toon path val"
Echo "  toon"

Lab end
; Clean up
UnSet toon_bin
UnSet toon_dir
UnSet toon_sub
UnSetEnv toon_rc
UnSetEnv toon_cpu
UnSetEnv toon_sdk
UnSetEnv toon_dest
