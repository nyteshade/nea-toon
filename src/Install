; Install script for toon - TOON format tools for AmigaOS
; Requires AmigaOS 2.0+ (requestchoice, requestfile)
;
; Usage: execute Install
;

; --- Welcome ---
requestchoice >ENV:toon_rc TITLE "TOON Installer" BODY "TOON v1.2*n*n  CLI, shared library, SDK" GADGETS "Install|Cancel"
IF $toon_rc EQ 0
  echo "Installation cancelled."
  SKIP end
ENDIF

; --- Select CPU for CLI binary ---
requestchoice >ENV:toon_cpu TITLE "Select CPU" BODY "Choose the toon CLI binary*nfor your CPU:" GADGETS "68000 (any Amiga)|68020|68040|68060"
IF $toon_cpu EQ 1
  echo >ENV:toon_bin "toon.000"
ENDIF
IF $toon_cpu EQ 2
  echo >ENV:toon_bin "toon.020"
ENDIF
IF $toon_cpu EQ 3
  echo >ENV:toon_bin "toon.040"
ENDIF
IF $toon_cpu EQ 0
  echo >ENV:toon_bin "toon.060"
ENDIF

IF NOT EXISTS $toon_bin
  echo "Error: $toon_bin not found."
  echo "Run Install from the toon directory."
  SKIP end
ENDIF

; --- Install CLI to C: ---
echo "Installing $toon_bin to C:toon..."
copy $toon_bin C:toon CLONE QUIET
IF WARN
  echo "Warning: Could not copy to C:"
ELSE
  echo "  C:toon installed."
ENDIF

; --- Install shared library to LIBS: ---
echo "Installing toon.library to LIBS:..."
IF EXISTS LIBS:toon.library
  echo "  Replacing existing toon.library..."
ENDIF
copy toon.library LIBS:toon.library CLONE QUIET
IF WARN
  echo "Warning: Could not copy to LIBS:"
ELSE
  echo "  LIBS:toon.library installed."
ENDIF

; --- Ask about SDK ---
requestchoice >ENV:toon_sdk TITLE "Developer SDK" BODY "Install SDK?*n*nHeaders, FD, pragmas, toon.lib" GADGETS "Yes|No"
IF $toon_sdk EQ 0
  echo "Skipping SDK installation."
  SKIP done
ENDIF

; --- Ask where to install SDK ---
requestfile >ENV:toon_dest TITLE "SDK Location" DRAWERSONLY NOICONS
IF WARN
  echo "No directory selected. Skipping SDK."
  SKIP done
ENDIF

; --- Create SDK directory structure ---
echo "Installing SDK to $toon_dest..."

IF NOT EXISTS "$toon_dest"
  makedir "$toon_dest"
ENDIF
IF NOT EXISTS "$toon_dest/include"
  makedir "$toon_dest/include"
ENDIF
IF NOT EXISTS "$toon_dest/include/libraries"
  makedir "$toon_dest/include/libraries"
ENDIF
IF NOT EXISTS "$toon_dest/include/proto"
  makedir "$toon_dest/include/proto"
ENDIF
IF NOT EXISTS "$toon_dest/include/pragmas"
  makedir "$toon_dest/include/pragmas"
ENDIF
IF NOT EXISTS "$toon_dest/include/fd"
  makedir "$toon_dest/include/fd"
ENDIF
IF NOT EXISTS "$toon_dest/lib"
  makedir "$toon_dest/lib"
ENDIF

; --- Copy SDK files ---
echo "  Copying header files..."
copy sdk/include/libraries/toon.h "$toon_dest/include/libraries/" CLONE QUIET
copy sdk/include/proto/toon.h "$toon_dest/include/proto/" CLONE QUIET
copy sdk/include/pragmas/toon_pragmas.h "$toon_dest/include/pragmas/" CLONE QUIET
copy sdk/include/fd/toon_lib.fd "$toon_dest/include/fd/" CLONE QUIET

echo "  Copying libraries..."
copy toon.library "$toon_dest/lib/" CLONE QUIET
copy sdk/toon.lib "$toon_dest/lib/" CLONE QUIET

echo "  Copying example..."
IF NOT EXISTS "$toon_dest/examples"
  makedir "$toon_dest/examples"
ENDIF
copy sdk/toon_example.c "$toon_dest/examples/" CLONE QUIET

echo "  SDK installed to $toon_dest"

; --- Done ---
LAB done
echo ""
echo "Installation complete!"
echo ""
echo "Quick start:"
echo "  toon encode file.json"
echo "  toon decode file.toon"
echo "  toon get file.toon path"
echo "  toon set file.toon path val"
echo "  toon"

LAB end
; Clean up env vars
delete ENV:toon_rc QUIET
delete ENV:toon_cpu QUIET
delete ENV:toon_bin QUIET
delete ENV:toon_sdk QUIET
delete ENV:toon_dest QUIET
