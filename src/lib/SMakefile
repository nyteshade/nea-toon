# SMakefile for toon.library - TOON format shared library for AmigaOS
# SAS/C 6.58
#
# Usage: smake                 build toon.library
#        smake example         build example caller
#        smake clean           remove build artifacts
#
# Requires SC: assign pointing to SAS/C installation.

CC = sc:c/sc
LD = sc:c/slink

# Library sources: the library wrapper + all core toon implementation files
LIBOBJS = toon_lib.o toon_decode.o toon_encode.o json_parse.o json_emit.o toon_util.o toon_path.o

# Compiler flags for library code
LIBCFLAGS = LIBCODE NOSTACKCHECK NOCHKABORT NOICONS IDLEN=80 IDIR=INCLUDE: IDIR=//src
LIBFDFILE = //include/fd/toon_lib.fd

# Compiler flags for example (caller)
EXCFLAGS = NOSTACKCHECK NOCHKABORT NOICONS IDLEN=80 IDIR=//include IDIR=INCLUDE:

LIBS = lib:sc.lib lib:amiga.lib

all: toon.library

toon.library: $(LIBOBJS)
	$(LD) with <<
LIBPREFIX _LIB
LIBFD $(LIBFDFILE)
FROM lib:libent.o lib:libinit.o $(LIBOBJS)
TO toon.library
LIB $(LIBS)
NOICONS SD
LIBVERSION 1 LIBREVISION 3
<

toon_lib.o: toon_lib.c //src/toon.h
	$(CC) $(LIBCFLAGS) LIBRARYFDFILE=$(LIBFDFILE) toon_lib.c

toon_decode.o: //src/toon_decode.c //src/toon.h
	$(CC) $(LIBCFLAGS) //src/toon_decode.c

toon_encode.o: //src/toon_encode.c //src/toon.h
	$(CC) $(LIBCFLAGS) //src/toon_encode.c

json_parse.o: //src/json_parse.c //src/toon.h
	$(CC) $(LIBCFLAGS) //src/json_parse.c

json_emit.o: //src/json_emit.c //src/toon.h
	$(CC) $(LIBCFLAGS) //src/json_emit.c

toon_util.o: //src/toon_util.c //src/toon.h
	$(CC) $(LIBCFLAGS) //src/toon_util.c

toon_path.o: //src/toon_path.c //src/toon.h
	$(CC) $(LIBCFLAGS) //src/toon_path.c

example: toon_example
toon_example: toon_example.o
	$(CC) LINK toon_example.o TO toon_example LIB lib:sc.lib lib:amiga.lib NOICONS

toon_example.o: toon_example.c
	$(CC) $(EXCFLAGS) toon_example.c

clean:
	-delete \#?.o quiet
	-delete toon.library quiet
	-delete toon_example quiet
